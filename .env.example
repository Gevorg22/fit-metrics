# ─── База данных (Neon / Vercel Postgres) ────────────────────────────────────
# Pooled connection — используется Prisma в рантайме
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/DATABASE?sslmode=require"

# Direct connection — используется для prisma migrate / prisma db push
DIRECT_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/DATABASE?sslmode=require"

# ─── Auth.js (NextAuth v5) ────────────────────────────────────────────────────
# Генерируется командой: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"

# URL приложения (без слеша в конце)
NEXTAUTH_URL="http://localhost:3000"

# ─── Resend (Magic Link Email) ────────────────────────────────────────────────
# Получить на https://resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Email-адрес отправителя (должен быть верифицирован в Resend)
EMAIL_FROM="fitMetrics <noreply@yourdomain.com>"
