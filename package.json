{
  "name": "fitmetrics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:push": "NODE_TLS_REJECT_UNAUTHORIZED=0 prisma db push",
    "db:migrate": "NODE_TLS_REJECT_UNAUTHORIZED=0 prisma migrate dev",
    "db:studio": "NODE_TLS_REJECT_UNAUTHORIZED=0 prisma studio",
    "db:generate": "prisma generate",
    "db:seed": "NODE_TLS_REJECT_UNAUTHORIZED=0 npx tsx prisma/seed.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.3.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-query": "^5.101.0",
    "@types/web-push": "^3.6.4",
    "antd": "^6.4.3",
    "next": "^16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "web-push": "^3.6.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sass": "^1.100.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.8"
  }
}
